# Environment variables para el AI Engine de Wadi
# Copiá este archivo como .env y completá tus keys

# -----------------------------------------------------------------------
# LLM Providers (al menos uno es requerido)
# -----------------------------------------------------------------------

# Groq (recomendado para MVP: gratis y ultrarrápido)
# Obtené tu key en: https://console.groq.com
GROQ_API_KEY=

# OpenAI (respaldo para tareas de alta complejidad)
# Obtené tu key en: https://platform.openai.com/api-keys
OPENAI_API_KEY=
